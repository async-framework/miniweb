{
  "manifest_version": 3,
  "name": "MiniWeb Local Redirect",
  "version": "0.0.0",
  "description": "Redirects the MiniWeb Tailscale preview hostname to the local MiniWeb preview server on this Mac.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://patrickjs-macbook-pro.lynx-in.ts.net/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "miniweb-local-redirect",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
